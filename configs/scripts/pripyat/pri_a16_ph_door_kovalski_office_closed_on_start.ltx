[logic]
active = ph_door@closed

[ph_door@closed]
closed = true
locked = false
on_use = ph_door@open
snd_open_start = metal_small_open ; Jurok
snd_close_start = metal_small_close_start ; Jurok
snd_close_stop = metal_small_close_stop ; Jurok

[ph_door@open]
closed = false
locked = false
on_use = ph_door@closed
on_game_timer = 50 | {=surge_started} ph_door@closed
snd_open_start = metal_small_open ; Jurok
snd_close_start = metal_small_close_start ; Jurok
snd_close_stop = metal_small_close_stop ; Jurok