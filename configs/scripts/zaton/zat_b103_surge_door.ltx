; Jurok start
[logic]
active = ph_door@open

[ph_door@close]
locked = false
closed = true
on_use = ph_door@open
on_info = {=surge_started =squad_exist(zat_b103_lost_merc_squad1) !squad_in_zone_all(zat_b103_lost_merc_squad1:zat_surge_hide_b103)} ph_door@open_2
snd_open_start = wood_large_open
snd_close_start = wood_large_close_start
snd_close_stop = wood_large_close_stop

[ph_door@open]
locked = false
closed = false
on_use = ph_door@close
on_info = {=surge_started =squad_exist(zat_b103_lost_merc_squad1) !squad_in_zone_all(zat_b103_lost_merc_squad1:zat_surge_hide_b103)} ph_door@open_2
snd_open_start = wood_large_open
snd_close_start = wood_large_close_start
snd_close_stop = wood_large_close_stop

[ph_door@open_2]
locked = false
closed = false
show_tips = false
on_info = {=surge_started =squad_exist(zat_b103_lost_merc_squad1) =squad_in_zone_all(zat_b103_lost_merc_squad1:zat_surge_hide_b103)} ph_door@lock
on_info2 = {=surge_complete} ph_door@open
snd_open_start = wood_large_open
snd_close_start = wood_large_close_start
snd_close_stop = wood_large_close_stop

[ph_door@lock]
locked = true
closed = true
on_info = {=surge_complete} ph_door@open
snd_open_start = trader_door_locked
; Jurok end