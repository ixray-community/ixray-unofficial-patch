[logic]
active = ph_door@close

[ph_door@close]
locked = false
closed = true
tip_open = tip_door_open
;tip_close = tip_door_close
on_use = ph_door@open
snd_open_start = wood_large_open ; Jurok
snd_close_start = wood_large_close_start ; Jurok
snd_close_stop = wood_large_close_stop ; Jurok

[ph_door@open]
locked = false
closed = false
;tip_open = tip_door_open
tip_close = tip_door_close
on_use = ph_door@close 
snd_open_start = wood_large_open ; Jurok
snd_close_start = wood_large_close_start ; Jurok
snd_close_stop = wood_large_close_stop ; Jurok